[
  {
    "start": 1.0,
    "end": 4.0,
    "text": "[ संगीत ]"
  },
  {
    "start": 4.0,
    "end": 8.0,
    "text": "नमस्कार आणि उत्कृष्टता अकादमीमध्ये आपले स्वागत आहे."
  },
  {
    "start": 8.0,
    "end": 11.0,
    "text": "आज आपण इंटीग्रेशन कडे पाहत आहोत."
  },
  {
    "start": 11.0,
    "end": 14.0,
    "text": "इंटीग्रेशन ही फक्त नद्या आहेत"
  },
  {
    "start": 14.0,
    "end": 15.0,
    "text": "डिफरेंशिएशन"
  },
  {
    "start": 15.0,
    "end": 19.0,
    "text": "मला वाय दिल्यास आम्ही सांगितलेले नोंदवा"
  },
  {
    "start": 19.0,
    "end": 22.0,
    "text": "x च्या बरोबर n ची शक्ती असणे"
  },
  {
    "start": 22.0,
    "end": 24.0,
    "text": "मग इंटीग्रेशन पासून"
  },
  {
    "start": 24.0,
    "end": 27.0,
    "text": "मी फरक केल्यास डिफरेंशिएशन पासून"
  },
  {
    "start": 27.0,
    "end": 31.0,
    "text": "x च्या संदर्भात y मला y सर्व मिळेल"
  },
  {
    "start": 31.0,
    "end": 34.0,
    "text": "एक्स वर आणि आम्ही संकल्पना सांगितले"
  },
  {
    "start": 34.0,
    "end": 37.0,
    "text": "डिफरेंशिएशन म्हणजे फक्त गुणाकार करणे"
  },
  {
    "start": 37.0,
    "end": 40.0,
    "text": "पाईची शक्ती n इतकी होते"
  },
  {
    "start": 40.0,
    "end": 41.0,
    "text": "एन."
  },
  {
    "start": 41.0,
    "end": 43.0,
    "text": "x ते आपण सांगितलेल्या शक्तीपर्यंत, त्यातील एक वजा करा."
  },
  {
    "start": 43.0,
    "end": 44.0,
    "text": "तुम्ही"
  },
  {
    "start": 44.0,
    "end": 46.0,
    "text": "एन होते"
  },
  {
    "start": 46.0,
    "end": 48.0,
    "text": "वजा एक म्हणून हे फक्त एक सोपे होते"
  },
  {
    "start": 48.0,
    "end": 51.0,
    "text": "डिफरेंशिएशन ची संकल्पना"
  },
  {
    "start": 51.0,
    "end": 54.0,
    "text": "जर मला ते दिले असेल तर इंटीग्रेशन साठी"
  },
  {
    "start": 54.0,
    "end": 58.0,
    "text": "y ओव्हर dx हे x च्या शक्तीच्या बरोबरीचे आहे"
  },
  {
    "start": 58.0,
    "end": 60.0,
    "text": "आता मला परत जाण्यासाठी"
  },
  {
    "start": 60.0,
    "end": 63.0,
    "text": "मौल्यवान चौरस मला करावा लागेल"
  },
  {
    "start": 63.0,
    "end": 65.0,
    "text": "समाकलित करा जेणेकरून आम्ही असे म्हटले"
  },
  {
    "start": 65.0,
    "end": 68.0,
    "text": "इंटीग्रेशन हे याच्या अगदी उलट आहे."
  },
  {
    "start": 68.0,
    "end": 69.0,
    "text": "डिफरेंशिएशन"
  },
  {
    "start": 69.0,
    "end": 71.0,
    "text": "तर या संकल्पनेसाठी आता पहिले प्रकरण"
  },
  {
    "start": 71.0,
    "end": 74.0,
    "text": "मी x येथे हलवीन"
  },
  {
    "start": 74.0,
    "end": 76.0,
    "text": "म्हणजे ही संख्या अर्धी होईल"
  },
  {
    "start": 76.0,
    "end": 78.0,
    "text": "जर एक्स इथे आला तर मी विद्युत असेन"
  },
  {
    "start": 78.0,
    "end": 79.0,
    "text": "वाय बरोबर सोडले"
  },
  {
    "start": 79.0,
    "end": 82.0,
    "text": "तर माझ्याकडे असेल की z y बरोबर आहे"
  },
  {
    "start": 82.0,
    "end": 85.0,
    "text": "x विरुद्ध m विरुद्ध x शक्तीला x होते"
  },
  {
    "start": 85.0,
    "end": 89.0,
    "text": "n आणि मग माझ्याकडे x आहे म्हणून हे बनते"
  },
  {
    "start": 89.0,
    "end": 92.0,
    "text": "x म्हणजे y हा x बार n च्या बरोबरीचा आहे आणि मग"
  },
  {
    "start": 92.0,
    "end": 94.0,
    "text": "x"
  },
  {
    "start": 94.0,
    "end": 94.0,
    "text": "उम."
  },
  {
    "start": 94.0,
    "end": 97.0,
    "text": "इंटीग्रेशन वरील समस्या ओळखल्या जातात"
  },
  {
    "start": 97.0,
    "end": 100.0,
    "text": "जेव्हा मी इंटीग्रल चिन्ह वापरतो"
  },
  {
    "start": 100.0,
    "end": 102.0,
    "text": "इंटीग्रल हे चिन्ह आहे"
  },
  {
    "start": 102.0,
    "end": 104.0,
    "text": "याला इंटीग्रल चिन्ह म्हणतात ठीक आहे"
  },
  {
    "start": 104.0,
    "end": 107.0,
    "text": "मी जोडल्यास त्याला इंटीग्रल चिन्ह म्हणतात"
  },
  {
    "start": 107.0,
    "end": 110.0,
    "text": "माझ्या डाव्या हाताच्या बाजूला इंटीग्रल चिन्ह आहे."
  },
  {
    "start": 110.0,
    "end": 113.0,
    "text": "आणि समीकरणाची उजवी बाजू माझ्याकडे आहे"
  },
  {
    "start": 113.0,
    "end": 116.0,
    "text": "की डी वाय चे इंटीग्रल"
  },
  {
    "start": 116.0,
    "end": 119.0,
    "text": "याला इंटीग्रल बाजू जोडण्याइतकेच आहे"
  },
  {
    "start": 119.0,
    "end": 123.0,
    "text": "x चा इंटीग्रल भागिले n आणि चा होतो"
  },
  {
    "start": 123.0,
    "end": 125.0,
    "text": "अभ्यासक्रम डीएक्स"
  },
  {
    "start": 125.0,
    "end": 126.0,
    "text": "जर तुम्ही या प्रक्रियेचे निरीक्षण करत असाल तर"
  },
  {
    "start": 126.0,
    "end": 129.0,
    "text": "डिफरेंशिएशन हे फक्त असे होते"
  },
  {
    "start": 129.0,
    "end": 131.0,
    "text": "मार्गाने गुणाकार करा आणि नंतर वजा करा"
  },
  {
    "start": 131.0,
    "end": 133.0,
    "text": "ज्याचे डिफरेंशिएशन होते"
  },
  {
    "start": 133.0,
    "end": 136.0,
    "text": "इंटीग्रेशन मी याच्या अगदी उलट करेन."
  },
  {
    "start": 136.0,
    "end": 138.0,
    "text": "तर हे आता होईल"
  },
  {
    "start": 138.0,
    "end": 141.0,
    "text": "जर मी y समाकलित केले तर तुम्हाला y मिळेल"
  },
  {
    "start": 141.0,
    "end": 143.0,
    "text": "यासाठी हे समाकलित करणे बरोबर आहे"
  },
  {
    "start": 143.0,
    "end": 147.0,
    "text": "आता डिफरेंशिएशन साठी मी n ने गुणाकार करतो"
  },
  {
    "start": 147.0,
    "end": 149.0,
    "text": "मी त्यांना वजा करतो म्हणून जर मी हे करत आहे"
  },
  {
    "start": 149.0,
    "end": 150.0,
    "text": "त्याऐवजी आता उलट"
  },
  {
    "start": 150.0,
    "end": 153.0,
    "text": "पुन्हा एक वजा करून मी त्यात एक जोडेन"
  },
  {
    "start": 153.0,
    "end": 157.0,
    "text": "पॉवरला x होते आणि मी आता जोडू"
  },
  {
    "start": 157.0,
    "end": 159.0,
    "text": "मध्ये वजा करण्याच्या विरुद्ध एक"
  },
  {
    "start": 159.0,
    "end": 162.0,
    "text": "डिफरेंशिएशन आणि नंतर देखील उलट"
  },
  {
    "start": 162.0,
    "end": 165.0,
    "text": "मी ज्या मार्गाने भागणार आहे त्या मार्गाने गुणाकार करण्यासाठी"
  },
  {
    "start": 165.0,
    "end": 167.0,
    "text": "पी. आय. च्या हो द्वारे"
  },
  {
    "start": 167.0,
    "end": 168.0,
    "text": "आणि"
  },
  {
    "start": 168.0,
    "end": 171.0,
    "text": "अधिक एक आणि अर्थातच स्थिरांक जोडा"
  },
  {
    "start": 171.0,
    "end": 175.0,
    "text": "अशा प्रकारे आपण इंटीग्रेशन करतो"
  },
  {
    "start": 175.0,
    "end": 177.0,
    "text": "शक्तीमध्ये एक जोडण्याइतके सोपे आणि"
  },
  {
    "start": 177.0,
    "end": 180.0,
    "text": "मग माझ्याकडे जे आहे ते भागून आपण"
  },
  {
    "start": 180.0,
    "end": 182.0,
    "text": "अगदी सोपी उदाहरणे घ्या आणि आपण पाहू"
  },
  {
    "start": 182.0,
    "end": 183.0,
    "text": "हे कसे?"
  },
  {
    "start": 185.0,
    "end": 187.0,
    "text": "येतो."
  },
  {
    "start": 187.0,
    "end": 189.0,
    "text": "इंटीग्रेशन वेगवेगळ्या पद्धती आहेत."
  },
  {
    "start": 189.0,
    "end": 192.0,
    "text": "इंटीग्रेशन करण्यासाठी उम आहे"
  },
  {
    "start": 192.0,
    "end": 194.0,
    "text": "पर्यायाद्वारे सामान्य पद्धत आहे"
  },
  {
    "start": 194.0,
    "end": 197.0,
    "text": "तेथे बायपास आहे आणि वगैरे घेतील"
  },
  {
    "start": 197.0,
    "end": 200.0,
    "text": "पद्धती एकापाठोपाठ एक आणि काम"
  },
  {
    "start": 200.0,
    "end": 202.0,
    "text": "त्यांच्यावर एकत्र पहिले सुरू करूया"
  },
  {
    "start": 202.0,
    "end": 204.0,
    "text": "इंटीग्रेशन ची पद्धत म्हणून ओळखली जाते"
  },
  {
    "start": 204.0,
    "end": 205.0,
    "text": "इंटीग्रेशन"
  },
  {
    "start": 205.0,
    "end": 208.0,
    "text": "सामान्य पद्धतीद्वारे तर प्रथम क्रमांक"
  },
  {
    "start": 208.0,
    "end": 222.0,
    "text": "प्रेरणेची सामान्य पद्धत"
  },
  {
    "start": 222.0,
    "end": 224.0,
    "text": "ठीक आहे तर बघूया की आम्हाला ते दिले गेले आहे"
  },
  {
    "start": 224.0,
    "end": 225.0,
    "text": "मुळात आम्ही विचारले"
  },
  {
    "start": 225.0,
    "end": 228.0,
    "text": "मूल्यमापन केले"
  },
  {
    "start": 228.0,
    "end": 233.0,
    "text": "युएचच्या इंटीग्रल ऐवजी"
  },
  {
    "start": 233.0,
    "end": 234.0,
    "text": "चार"
  },
  {
    "start": 234.0,
    "end": 240.0,
    "text": "x घन वजा दोन x वर्ग अधिक सहा x"
  },
  {
    "start": 240.0,
    "end": 241.0,
    "text": "अधिक"
  },
  {
    "start": 241.0,
    "end": 242.0,
    "text": "सात"
  },
  {
    "start": 242.0,
    "end": 244.0,
    "text": "डीएक्स"
  },
  {
    "start": 244.0,
    "end": 244.0,
    "text": "बरोबर."
  },
  {
    "start": 244.0,
    "end": 246.0,
    "text": "समजा तुम्ही एका जागेबद्दल विचारत आहात"
  },
  {
    "start": 246.0,
    "end": 248.0,
    "text": "हे जेव्हा होते तेव्हा तुमच्या आता काय लक्षात येते?"
  },
  {
    "start": 248.0,
    "end": 251.0,
    "text": "इंटीग्रेशन वर पहिल्यांदा तुम्ही आलात"
  },
  {
    "start": 251.0,
    "end": 253.0,
    "text": "हे तुमचे इंटीग्रल व्हेरिएबल आहे का ते पहा."
  },
  {
    "start": 253.0,
    "end": 256.0,
    "text": "हा x आहे ज्याला इंटीग्रल म्हणतात."
  },
  {
    "start": 256.0,
    "end": 258.0,
    "text": "चल म्हणजे मी हे समाकलित करीत आहे"
  },
  {
    "start": 258.0,
    "end": 261.0,
    "text": "x च्या संदर्भात संपूर्ण कार्य जे आहे"
  },
  {
    "start": 261.0,
    "end": 263.0,
    "text": "याचा अर्थ काय आहे म्हणून जर मी समाकलित केले तर काय करावे"
  },
  {
    "start": 263.0,
    "end": 265.0,
    "text": "मी आता इंटीग्रेशन चा विचार करतो"
  },
  {
    "start": 265.0,
    "end": 268.0,
    "text": "आणि जर मी खरोखरच एक संख्या समाकलित करत आहे"
  },
  {
    "start": 268.0,
    "end": 270.0,
    "text": "अशा गोष्टींची"
  },
  {
    "start": 270.0,
    "end": 273.0,
    "text": "मुख्य संकल्पना ही असेल की मी असेन"
  },
  {
    "start": 273.0,
    "end": 276.0,
    "text": "प्रत्येक दहासाठी इंटीग्रल चिन्ह"
  },
  {
    "start": 276.0,
    "end": 278.0,
    "text": "आणि नक्कीच मी आता x जोडणार आहे"
  },
  {
    "start": 278.0,
    "end": 280.0,
    "text": "ते सर्व बरोबर आहेत म्हणून कार्ये घेतात"
  },
  {
    "start": 280.0,
    "end": 282.0,
    "text": "प्रत्येकासाठी ग्राउंड चिन्ह"
  },
  {
    "start": 282.0,
    "end": 285.0,
    "text": "दहा म्हणून चार x चौकोनी आकारासह इंटीग्रल चिन्ह"
  },
  {
    "start": 285.0,
    "end": 288.0,
    "text": "आणि मग हा x आता मला देईल"
  },
  {
    "start": 288.0,
    "end": 290.0,
    "text": "इंटीग्रल"
  },
  {
    "start": 290.0,
    "end": 290.0,
    "text": "चार"
  },
  {
    "start": 290.0,
    "end": 292.0,
    "text": "x क्यूब आणि नंतर"
  },
  {
    "start": 292.0,
    "end": 294.0,
    "text": "एक्स"
  },
  {
    "start": 294.0,
    "end": 297.0,
    "text": "यावेळी हेक्स वजा वजा टेक होतो"
  },
  {
    "start": 297.0,
    "end": 300.0,
    "text": "याला इंटीग्रल चिन्ह आणि x बनतो"
  },
  {
    "start": 300.0,
    "end": 303.0,
    "text": "इंटीग्रल दोन x वर्ग"
  },
  {
    "start": 303.0,
    "end": 307.0,
    "text": "डीएक्स पुढील एक अधिक म्हणून माझ्याकडे अधिक आहे"
  },
  {
    "start": 307.0,
    "end": 310.0,
    "text": "अधिक चिन्ह 6x आणि नंतर x वर घेऊन"
  },
  {
    "start": 310.0,
    "end": 314.0,
    "text": "कारण समाकलन 6 x ते x"
  },
  {
    "start": 314.0,
    "end": 319.0,
    "text": "अधिक शेवटी इंटीग्रल ते x होते"
  },
  {
    "start": 319.0,
    "end": 321.0,
    "text": "इंटीग्रल 7"
  },
  {
    "start": 321.0,
    "end": 323.0,
    "text": "डीएक्स"
  },
  {
    "start": 323.0,
    "end": 324.0,
    "text": "म्हणून माझ्याकडे हे आहे"
  },
  {
    "start": 324.0,
    "end": 326.0,
